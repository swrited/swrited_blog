---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'swrited 的个人博客，记录 AI、工程、部署与日常折腾。'
} = Astro.props;

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/+$/, '');
};

const pathname = normalizePath(Astro.url.pathname);
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/papers', label: 'Papers' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' }
].map((item) => ({
  ...item,
  normalizedHref: normalizePath(item.href)
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/images/inni/inni-logo.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <img src="/images/inni/inni-logo.svg" alt="inni logo" class="brand-logo-icon" />
          <img src="/images/inni/logo-文字.svg" alt="swrited & inni" class="brand-logo-text" />
        </a>
        <div class="topbar-actions">
          <nav class="nav">
            {navItems.map((item) => (
              <a href={item.href} class={pathname === item.normalizedHref || pathname.startsWith(`${item.normalizedHref}/`) ? 'nav-link is-active' : 'nav-link'}>
                {item.label}
              </a>
            ))}
          </nav>
          <div class="topbar-links">
          </div>
        </div>
      </div>
    </header>
    <div class="site-shell">
      <main>
        <slot />
      </main>
      <footer class="footer">
        <span>Built with Astro.</span>
        <span>swrited & inni · blog</span>
      </footer>
    </div>
  </body>
</html>
