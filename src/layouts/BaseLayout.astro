---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'swrited 的个人博客，记录 AI、工程、部署与日常折腾。'
} = Astro.props;

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/+$/, '');
};

const pathname = normalizePath(Astro.url.pathname);
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/papers', label: 'Papers' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' }
].map((item) => ({
  ...item,
  normalizedHref: normalizePath(item.href)
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/images/inni/inni-logo.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <img src="/images/inni/inni-logo.svg" alt="inni logo" class="brand-logo-icon" />
          <img src="/images/inni/logo-文字.svg" alt="swrited & inni" class="brand-logo-text" />
        </a>
        <div class="topbar-actions">
          <nav class="nav">
            {navItems.map((item) => (
              <a href={item.href} class={pathname === item.normalizedHref || pathname.startsWith(`${item.normalizedHref}/`) ? 'nav-link is-active' : 'nav-link'}>
                {item.label}
              </a>
            ))}
          </nav>
          <div class="topbar-links">
          </div>
        </div>
      </div>
    </header>
    <div class="site-shell">
      <main>
        <slot />
      </main>
      <footer class="footer">
        <span>Built with Astro.</span>
        <span>swrited & inni · blog</span>
        <span id="visit-counter" class="visit-counter">👀 <span id="visit-count">...</span> visits</span>
      </footer>
    </div>
    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');

      function setupScrollProgress() {
        const progress = document.createElement('div');
        progress.className = 'scroll-progress';
        progress.setAttribute('aria-hidden', 'true');
        document.body.appendChild(progress);

        let ticking = false;
        const sync = () => {
          const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
          const percent = Math.min(100, Math.max(0, (window.scrollY / maxScroll) * 100));
          document.documentElement.style.setProperty('--scroll-progress', `${percent}%`);
          ticking = false;
        };

        const requestSync = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(sync);
        };

        sync();
        window.addEventListener('scroll', requestSync, { passive: true });
        window.addEventListener('resize', requestSync);
      }

      function setupCardHighlights() {
        if (reduceMotion.matches || !finePointer.matches) return;

        document.querySelectorAll('.post-card').forEach((card) => {
          card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 100;
            const y = ((event.clientY - rect.top) / rect.height) * 100;
            card.style.setProperty('--card-x', `${x.toFixed(1)}%`);
            card.style.setProperty('--card-y', `${y.toFixed(1)}%`);
          }, { passive: true });
        });
      }

      function setupTopbar() {
        const topbar = document.querySelector('.topbar');
        if (!topbar) return;

        const sync = () => {
          topbar.classList.toggle('is-scrolled', window.scrollY > 18);
        };

        sync();
        window.addEventListener('scroll', sync, { passive: true });
      }

      function setupBackgroundParallax() {
        if (reduceMotion.matches) return;

        let ticking = false;
        const sync = () => {
          const shift = Math.max(-42, Math.min(0, window.scrollY * -0.035));
          document.documentElement.style.setProperty('--bg-shift', `${shift}px`);
          ticking = false;
        };

        const requestSync = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(sync);
        };

        sync();
        window.addEventListener('scroll', requestSync, { passive: true });
      }

      function setupCardReveal() {
        if (reduceMotion.matches) return;

        const revealItems = document.querySelectorAll('.post-card, .section-summary-card');
        if (!revealItems.length) return;

        revealItems.forEach((item) => item.classList.add('is-revealable'));

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          });
        }, {
          rootMargin: '0px 0px -10% 0px',
          threshold: 0.14
        });

        revealItems.forEach((item) => observer.observe(item));

        window.setTimeout(() => {
          revealItems.forEach((item) => {
            item.classList.add('is-visible');
            observer.unobserve(item);
          });
        }, 900);
      }

      function setupPetals() {
        if (reduceMotion.matches) return;

        const createLayer = (isFront = false) => {
          const layer = document.createElement('div');
          const count = isFront
            ? (window.innerWidth < 720 ? 5 : 8)
            : (window.innerWidth < 720 ? 14 : 24);

          layer.className = isFront ? 'flower-petal-field is-front' : 'flower-petal-field';
          layer.setAttribute('aria-hidden', 'true');

          for (let i = 0; i < count; i += 1) {
            const petal = document.createElement('span');
            const size = isFront ? 16 + Math.random() * 14 : 7 + Math.random() * 9;
            const drift = (Math.random() * (isFront ? 150 : 120) - (isFront ? 75 : 60)).toFixed(1);

            petal.className = isFront ? 'flower-petal is-front' : 'flower-petal';
            petal.style.setProperty('--x', String(Math.random() * 100));
            petal.style.setProperty('--size', `${size.toFixed(1)}px`);
            petal.style.setProperty('--alpha', String(isFront ? 0.46 + Math.random() * 0.22 : 0.24 + Math.random() * 0.3));
            petal.style.setProperty('--duration', `${isFront ? 10 + Math.random() * 8 : 13 + Math.random() * 13}s`);
            petal.style.setProperty('--delay', `${Math.random() * -18}s`);
            petal.style.setProperty('--drift', `${drift}px`);
            petal.style.setProperty('--rotation', `${Math.random() * 360}deg`);
            layer.appendChild(petal);
          }

          document.body.appendChild(layer);
        };

        createLayer(false);
        createLayer(true);
      }

      setupScrollProgress();
      setupCardHighlights();
      setupTopbar();
      setupBackgroundParallax();
      setupCardReveal();
      setupPetals();

      // visit counter
      (function setupCounter() {
        const el = document.getElementById('visit-count');
        if (!el) return;
        const key = 'swrited-blog-visited';
        fetch('/api/counter', { method: sessionStorage.getItem(key) ? 'GET' : 'POST' })
          .then(r => r.json())
          .then(data => { el.textContent = data.total; })
          .catch(() => { el.textContent = '—'; });
        if (!sessionStorage.getItem(key)) sessionStorage.setItem(key, '1');
      })();
    </script>
  </body>
</html>
