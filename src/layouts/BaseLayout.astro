---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'swrited 的个人博客，记录 AI、工程、部署与日常折腾。'
} = Astro.props;

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/+$/, '');
};

const pathname = normalizePath(Astro.url.pathname);
const navItems = [
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' }
].map((item) => ({
  ...item,
  normalizedHref: normalizePath(item.href)
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark"></span>
          <span class="brand-copy">
            <span class="brand-name">swrited</span>
            <span class="brand-subtitle">build · write · recover</span>
          </span>
        </a>
        <div class="topbar-actions">
          <nav class="nav">
            {navItems.map((item) => (
              <a href={item.href} class={pathname === item.normalizedHref || pathname.startsWith(`${item.normalizedHref}/`) ? 'nav-link is-active' : 'nav-link'}>
                {item.label}
              </a>
            ))}
          </nav>
          <div class="topbar-links">
            <a class="topbar-link" href="https://github.com/swrited" target="_blank" rel="noreferrer">GitHub</a>
            <a class="topbar-link" href="mailto:swrited@hotmail.com">Mail</a>
          </div>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <span>Built with Astro.</span>
        <span>blog.swrited.top</span>
      </footer>
    </div>
  </body>
</html>
