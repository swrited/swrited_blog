<div id="live2d-inni">
  <canvas id="live2d-canvas"></canvas>
</div>

<style>
  #live2d-inni {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    pointer-events: none;
    user-select: none;
  }
  #live2d-canvas {
    width: 240px;
    height: 280px;
    pointer-events: all;
    cursor: grab;
    -webkit-user-drag: none;
  }
  #live2d-canvas:active {
    cursor: grabbing;
  }
  /* 移动端默认隐藏 */
  @media (max-width: 768px) {
    #live2d-inni {
      display: none;
    }
  }
</style>

<script is:inline>
(function initLive2dInni() {
  const canvasEl = document.getElementById('live2d-canvas');
  const wrapper = document.getElementById('live2d-inni');
  if (!canvasEl || !wrapper) return;

  // 用临时 canvas 探测 WebGL，避免污染主 canvas
  var testCanvas = document.createElement('canvas');
  var gl = testCanvas.getContext('webgl');
  if (!gl) {
    wrapper.style.display = 'none';
    var pixelInni = document.getElementById('inni-companion');
    if (pixelInni) pixelInni.style.display = 'block';
    return;
  }

  // 位置状态
  let currentX = window.innerWidth - 280;
  let currentY = window.innerHeight - 320;
  let isDragging = false;
  let dragOffsetX = 0;
  let dragOffsetY = 0;

  const savedX = sessionStorage.getItem('live2d-inni-x');
  const savedY = sessionStorage.getItem('live2d-inni-y');
  if (savedX && savedY) {
    currentX = parseFloat(savedX);
    currentY = parseFloat(savedY);
  }

  wrapper.style.cssText = 'position:fixed;left:' + currentX + 'px;top:' + currentY + 'px;z-index:9999;pointer-events:none;user-select:none;';

  // 按序加载外部脚本
  function loadScript(src) {
    return new Promise(function(resolve, reject) {
      var s = document.createElement('script');
      s.src = src;
      s.onload = function() { resolve(); };
      s.onerror = function() { reject(new Error('Failed to load ' + src)); };
      document.head.appendChild(s);
    });
  }

  async function boot() {
    try {
      await loadScript('/live2d-lib/pixi.min.js');
      await loadScript('/live2d-lib/live2dcubismcore.min.js');
      await loadScript('/live2d-lib/cubism4.min.js');
    } catch (e) {
      console.error('[Live2D Inni] 依赖加载失败', e);
      wrapper.style.display = 'none';
      var pixelInni = document.getElementById('inni-companion');
      if (pixelInni) pixelInni.style.display = 'block';
      return;
    }

    var PIXI = window.PIXI;
    var Live2DModel = PIXI && PIXI.live2d && PIXI.live2d.Live2DModel;
    if (!PIXI || !Live2DModel) {
      console.error('[Live2D Inni] PIXI 或 Live2DModel 未找到');
      wrapper.style.display = 'none';
      var pixelInni = document.getElementById('inni-companion');
      if (pixelInni) pixelInni.style.display = 'block';
      return;
    }

    Live2DModel.registerTicker(PIXI.Ticker);

    var app = new PIXI.Application({
      view: canvasEl,
      width: 240,
      height: 280,
      backgroundAlpha: 0,
      antialias: true,
      resolution: Math.min(window.devicePixelRatio || 1, 2),
      autoDensity: true,
    });

    var model = null;

    try {
      model = await Live2DModel.from('/images/inni/live2d/inni_2_eye.model3.json');
    } catch (e) {
      console.error('[Live2D Inni] 模型加载失败', e);
      app.destroy(true, { children: true, texture: true, baseTexture: true });
      wrapper.style.display = 'none';
      var pixelInni = document.getElementById('inni-companion');
      if (pixelInni) pixelInni.style.display = 'block';
      return;
    }

    app.stage.addChild(model);

    // 缩放与居中
    var scale = Math.min(240 / model.width, 280 / model.height) * 1.2;
    model.scale.set(scale);
    model.x = 240 / 2;
    model.y = 280 / 2;
    model.anchor.set(0.5, 0.5);

    // 自动眨眼/呼吸（通过参数）
    var blinkTimer = 0;
    var blinkState = 0; // 0: open, 1: closing, 2: opening
    var blinkValue = 1; // 1 = open, 0 = closed
    var ticker = function() {
      // 简单自动眨眼模拟（每 3~5 秒随机）
      blinkTimer -= 1 / 60;
      if (blinkState === 0 && blinkTimer <= 0) {
        blinkState = 1;
      }
      if (blinkState === 1) {
        blinkValue -= 0.15;
        if (blinkValue <= 0) {
          blinkValue = 0;
          blinkState = 2;
        }
      } else if (blinkState === 2) {
        blinkValue += 0.15;
        if (blinkValue >= 1) {
          blinkValue = 1;
          blinkState = 0;
          blinkTimer = 3 + Math.random() * 2;
        }
      }
      if (model && model.internalModel) {
        var core = model.internalModel.coreModel;
        if (core && typeof core.setParameterValueById === 'function') {
          core.setParameterValueById('ParamEyeLOpen', blinkValue);
          core.setParameterValueById('ParamEyeROpen', blinkValue);
        }
      }
    };
    app.ticker.add(ticker);

    // 鼠标跟踪
    var targetAngleX = 0;
    var targetAngleY = 0;
    var currentAngleX = 0;
    var currentAngleY = 0;

    document.addEventListener('mousemove', function(e) {
      if (!model) return;
      var rect = canvasEl.getBoundingClientRect();
      var centerX = rect.left + rect.width / 2;
      var centerY = rect.top + rect.height / 2;
      var dx = e.clientX - centerX;
      var dy = e.clientY - centerY;
      var maxAngle = 15;
      targetAngleX = Math.max(-maxAngle, Math.min(maxAngle, dx / 20));
      targetAngleY = Math.max(-maxAngle, Math.min(maxAngle, dy / 20));
    });

    app.ticker.add(function() {
      if (!model || !model.internalModel) return;
      currentAngleX += (targetAngleX - currentAngleX) * 0.1;
      currentAngleY += (targetAngleY - currentAngleY) * 0.1;
      var core = model.internalModel.coreModel;
      if (core && typeof core.setParameterValueById === 'function') {
        core.setParameterValueById('ParamAngleX', currentAngleX);
        core.setParameterValueById('ParamAngleY', currentAngleY);
      }
    });

    // 拖动逻辑
    canvasEl.addEventListener('mousedown', function(e) {
      isDragging = true;
      dragOffsetX = e.clientX - wrapper.offsetLeft;
      dragOffsetY = e.clientY - wrapper.offsetTop;
      e.preventDefault();
    });

    document.addEventListener('mousemove', function(e) {
      if (!isDragging) return;
      currentX = e.clientX - dragOffsetX;
      currentY = e.clientY - dragOffsetY;
      wrapper.style.left = currentX + 'px';
      wrapper.style.top = currentY + 'px';
    });

    document.addEventListener('mouseup', function() {
      if (!isDragging) return;
      isDragging = false;
      sessionStorage.setItem('live2d-inni-x', String(currentX));
      sessionStorage.setItem('live2d-inni-y', String(currentY));
    });

    // Swup 页面切换时销毁并重建（防止 WebGL context 泄漏）
    var onPageView = function() {
      if (app && !app.destroyed) {
        app.ticker.remove(ticker);
        app.destroy(true, { children: true, texture: true, baseTexture: true });
      }
      // 重建
      boot();
    };

    if (window.swup && window.swup.hooks) {
      window.swup.hooks.on('page:view', onPageView);
    } else {
      document.addEventListener('swup:enable', function() {
        window.swup.hooks.on('page:view', onPageView);
      });
    }
  }

  boot();
})();
</script>
