<div id="live2d-inni">
  <canvas id="live2d-canvas"></canvas>
</div>

<style>
  #live2d-inni {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    pointer-events: none;
    user-select: none;
  }
  #live2d-canvas {
    width: 240px;
    height: 280px;
    pointer-events: all;
    cursor: grab;
    -webkit-user-drag: none;
  }
  #live2d-canvas:active {
    cursor: grabbing;
  }
  /* 移动端默认隐藏 */
  @media (max-width: 768px) {
    #live2d-inni {
      display: none;
    }
  }
</style>

<script>
  (function initLive2dInni() {
    // 如果当前是 IE 或者没有 WebGL，回退到像素版（不执行 Live2D）
    const canvasEl = document.getElementById('live2d-canvas') as HTMLCanvasElement | null;
    const wrapper = document.getElementById('live2d-inni');
    if (!canvasEl || !wrapper) return;

    const gl = canvasEl.getContext('webgl');
    if (!gl) {
      // WebGL 不支持，隐藏自己，让像素版显示
      wrapper.style.display = 'none';
      const pixelInni = document.getElementById('inni-companion');
      if (pixelInni) pixelInni.style.display = 'block';
      return;
    }

    // 先释放测试用的 context
    const loseExt = gl.getExtension('WEBGL_lose_context');
    if (loseExt) loseExt.loseContext();

    // 位置状态
    let currentX = window.innerWidth - 280;
    let currentY = window.innerHeight - 320;
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;

    const savedX = sessionStorage.getItem('live2d-inni-x');
    const savedY = sessionStorage.getItem('live2d-inni-y');
    if (savedX && savedY) {
      currentX = parseFloat(savedX);
      currentY = parseFloat(savedY);
    }

    wrapper.style.cssText = `position:fixed;left:${currentX}px;top:${currentY}px;z-index:9999;pointer-events:none;user-select:none;`;

    // 按序加载外部脚本
    function loadScript(src: string): Promise<void> {
      return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = src;
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('Failed to load ' + src));
        document.head.appendChild(s);
      });
    }

    async function boot() {
      try {
        await loadScript('/live2d-lib/pixi.min.js');
        await loadScript('/live2d-lib/live2dcubismcore.min.js');
        await loadScript('/live2d-lib/cubism4.min.js');
      } catch (e) {
        console.error('[Live2D Inni] 依赖加载失败', e);
        wrapper.style.display = 'none';
        const pixelInni = document.getElementById('inni-companion');
        if (pixelInni) pixelInni.style.display = 'block';
        return;
      }

      const PIXI = (window as any).PIXI;
      const Live2DModel = PIXI?.live2d?.Live2DModel;
      if (!PIXI || !Live2DModel) {
        console.error('[Live2D Inni] PIXI 或 Live2DModel 未找到');
        wrapper.style.display = 'none';
        const pixelInni = document.getElementById('inni-companion');
        if (pixelInni) pixelInni.style.display = 'block';
        return;
      }

      Live2DModel.registerTicker(PIXI.Ticker);

      const app = new PIXI.Application({
        view: canvasEl,
        width: 240,
        height: 280,
        backgroundAlpha: 0,
        antialias: true,
        resolution: Math.min(window.devicePixelRatio || 1, 2),
        autoDensity: true,
      });

      let model: any = null;

      try {
        model = await Live2DModel.from('/images/inni/live2d/inni_2_eye.model3.json');
      } catch (e) {
        console.error('[Live2D Inni] 模型加载失败', e);
        app.destroy(true, { children: true, texture: true, baseTexture: true });
        wrapper.style.display = 'none';
        const pixelInni = document.getElementById('inni-companion');
        if (pixelInni) pixelInni.style.display = 'block';
        return;
      }

      app.stage.addChild(model);

      // 缩放与居中
      const scale = Math.min(240 / model.width, 280 / model.height) * 1.2;
      model.scale.set(scale);
      model.x = 240 / 2;
      model.y = 280 / 2;
      model.anchor.set(0.5, 0.5);

      // 自动眨眼/呼吸（通过参数）
      let blinkTimer = 0;
      let blinkState = 0; // 0: open, 1: closing, 2: opening
      let blinkValue = 1; // 1 = open, 0 = closed
      const ticker = () => {
        // 简单自动眨眼模拟（每 3~5 秒随机）
        blinkTimer -= 1 / 60;
        if (blinkState === 0 && blinkTimer <= 0) {
          blinkState = 1;
        }
        if (blinkState === 1) {
          blinkValue -= 0.15;
          if (blinkValue <= 0) {
            blinkValue = 0;
            blinkState = 2;
          }
        } else if (blinkState === 2) {
          blinkValue += 0.15;
          if (blinkValue >= 1) {
            blinkValue = 1;
            blinkState = 0;
            blinkTimer = 3 + Math.random() * 2;
          }
        }
        if (model && model.internalModel) {
          const core = model.internalModel.coreModel;
          if (core && typeof core.setParameterValueById === 'function') {
            core.setParameterValueById('ParamEyeLOpen', blinkValue);
            core.setParameterValueById('ParamEyeROpen', blinkValue);
          }
        }
      };
      app.ticker.add(ticker);

      // 鼠标跟踪
      let targetAngleX = 0;
      let targetAngleY = 0;
      let currentAngleX = 0;
      let currentAngleY = 0;

      document.addEventListener('mousemove', (e) => {
        if (!model) return;
        const rect = canvasEl.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        const dx = e.clientX - centerX;
        const dy = e.clientY - centerY;
        const maxAngle = 15;
        targetAngleX = Math.max(-maxAngle, Math.min(maxAngle, dx / 20));
        targetAngleY = Math.max(-maxAngle, Math.min(maxAngle, dy / 20));
      });

      app.ticker.add(() => {
        if (!model || !model.internalModel) return;
        currentAngleX += (targetAngleX - currentAngleX) * 0.1;
        currentAngleY += (targetAngleY - currentAngleY) * 0.1;
        const core = model.internalModel.coreModel;
        if (core && typeof core.setParameterValueById === 'function') {
          core.setParameterValueById('ParamAngleX', currentAngleX);
          core.setParameterValueById('ParamAngleY', currentAngleY);
        }
      });

      // 拖动逻辑
      canvasEl.addEventListener('mousedown', (e) => {
        isDragging = true;
        dragOffsetX = e.clientX - wrapper.offsetLeft;
        dragOffsetY = e.clientY - wrapper.offsetTop;
        e.preventDefault();
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        currentX = e.clientX - dragOffsetX;
        currentY = e.clientY - dragOffsetY;
        wrapper.style.left = currentX + 'px';
        wrapper.style.top = currentY + 'px';
      });

      document.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        sessionStorage.setItem('live2d-inni-x', String(currentX));
        sessionStorage.setItem('live2d-inni-y', String(currentY));
      });

      // Swup 页面切换时销毁并重建（防止 WebGL context 泄漏）
      const onPageView = () => {
        if (app && !app.destroyed) {
          app.ticker.remove(ticker);
          app.destroy(true, { children: true, texture: true, baseTexture: true });
        }
        // 重建
        boot();
      };

      if ((window as any).swup?.hooks) {
        (window as any).swup.hooks.on('page:view', onPageView);
      } else {
        document.addEventListener('swup:enable', () => {
          (window as any).swup.hooks.on('page:view', onPageView);
        });
      }
    }

    boot();
  })();
</script>
