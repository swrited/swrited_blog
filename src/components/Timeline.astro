---
import { timeline, type TimelineEntry } from "@/data/timeline";

interface Props {
    entries?: TimelineEntry[];
    class?: string;
}

const { entries = timeline, class: className = "" } = Astro.props;
---

<ol class:list={["timeline", className]}>
    {
        entries.map((entry) => (
            <li class="timeline-item">
                <div class="timeline-year">{entry.year}</div>
                <div class="timeline-marker">
                    <span class="timeline-dot" />
                </div>
                <ul
                    class:list={[
                        "timeline-details",
                        { "timeline-details-single": entry.details.length === 1 },
                    ]}
                >
                    {entry.details.map((d) => (
                        <li>{d}</li>
                    ))}
                </ul>
            </li>
        ))
    }
</ol>

<style>
    .timeline {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 1.25rem;
    }
    .timeline-item {
        display: grid;
        grid-template-columns: 4rem 1.5rem 1fr;
        align-items: start;
        gap: 0.5rem;
        padding-bottom: 0.85rem;
    }
    .timeline-item:last-child {
        padding-bottom: 0;
    }
    .timeline-year {
        text-align: right;
        font-weight: 700;
        color: var(--primary);
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
        padding-top: 0.1rem;
        letter-spacing: 0.02em;
    }
    .timeline-marker {
        position: relative;
        height: 100%;
        display: flex;
        justify-content: center;
        padding-top: 0.5rem;
    }
    .timeline-dot {
        position: relative;
        z-index: 1;
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 50%;
        background: var(--primary);
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--primary), transparent 85%);
    }
    .timeline-item:not(:last-child) .timeline-marker::before {
        content: "";
        position: absolute;
        top: 1.05rem;
        left: 50%;
        transform: translateX(-50%);
        width: 2px;
        height: calc(100% + 0.2rem);
        background: color-mix(in oklch, var(--primary), transparent 70%);
    }
    .timeline-details {
        list-style: disc;
        padding-left: 1.1rem;
        margin: 0;
        font-size: 0.875rem;
        color: color-mix(in oklch, var(--primary), transparent 25%);
        line-height: 1.5;
    }
    .timeline-details-single {
        list-style: none;
        padding-left: 0;
        font-size: 1rem;
        line-height: 1.4;
    }
    .timeline-details li {
        margin-bottom: 0.15rem;
    }
    .timeline-details li:last-child {
        margin-bottom: 0;
    }
</style>
