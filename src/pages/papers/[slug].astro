---
import BackLink from '../../components/BackLink.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await paper.render();

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${paper.data.title} | Papers`} description={paper.data.summary}>
  <BackLink href="/papers" label="返回论文列表" />

  <article class="article">
    <header class="article-header">
      {paper.data.venue && <span class="eyebrow">{paper.data.venue}</span>}
      <h1>{paper.data.title}</h1>
      {paper.data.authors && (
        <p class="article-authors">{paper.data.authors}</p>
      )}
      <div class="article-meta">
        <span>{formatDate(paper.data.pubDate)}</span>
        {paper.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      {paper.data.paperUrl && (
        <a class="article-paper-link" href={paper.data.paperUrl} target="_blank" rel="noreferrer">
          📄 查看原文
        </a>
      )}
    </header>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<script>
  import mediumZoom from 'medium-zoom';

  mediumZoom('.article-body img', {
    background: 'rgba(0,0,0,0.82)',
    margin: 24
  });
</script>

<style>
  .article-authors {
    font-size: 0.9rem;
    color: var(--soft);
    font-style: italic;
    margin: 12px 0;
  }
  .article-paper-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.88rem;
    color: var(--blue);
    font-weight: 500;
  }
  .article-paper-link:hover {
    opacity: 0.7;
  }
</style>