---
import BackLink from '../../components/BackLink.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Papers | swrited & inni" description="论文精读笔记。">
  <BackLink href="/" label="返回首页" />

  <section class="page-header">
    <span class="eyebrow">PAPERS</span>
    <h1>论文精读</h1>
    <p>对感兴趣的技术论文进行深度阅读与笔记整理。</p>
  </section>

  <section class="post-list">
    {papers.map((paper) => (
      <a class="card post-card" href={`/papers/${paper.id}`}>
        <div class="post-card-body">
          <div class="post-meta-row">
            <div class="post-meta">
              <span>{formatDate(paper.data.pubDate)}</span>
              {paper.data.venue && <span class="post-meta-sep">·</span>}
              {paper.data.venue && <span>{paper.data.venue}</span>}
            </div>
            {paper.data.tags.length > 0 && (
              <div class="tag-row post-tags">
                {paper.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <h3>{paper.data.title}</h3>
          {paper.data.authors && (
            <p class="paper-authors">{paper.data.authors}</p>
          )}
          <p>{paper.data.summary}</p>
          <div class="post-card-footer">
            <span class="text-link">阅读笔记 →</span>
          </div>
        </div>
      </a>
    ))}
    {papers.length === 0 && (
      <p style="color: var(--soft);">暂无论文笔记，敬请期待。</p>
    )}
  </section>
</BaseLayout>

<style>
  .paper-authors {
    font-size: 0.82rem;
    color: var(--soft);
    margin: 4px 0;
    font-style: italic;
  }
</style>