---
import GridLayout from "@layouts/grid.astro";
import Live2DPlayer from "@components/live2dPlayer.astro";
import Comment from "@components/comment.astro";
import { live2dModels, type Live2DModelEntry } from "@/data/live2d-models";

export async function getStaticPaths() {
    return live2dModels.map((m) => ({
        params: { slug: m.slug },
        props: { model: m },
    }));
}

interface Props {
    model: Live2DModelEntry;
}

const { model } = Astro.props;

function linkify(text: string): string {
    const esc = text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    return esc.replace(
        /(https?:\/\/[^\s<>,，。；;)]+)/g,
        '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-(--primary) underline decoration-(--primary)/40 hover:decoration-(--primary)">$1</a>'
    );
}
---

<GridLayout title={model.name} description={`Live2D model: ${model.name}`}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <a
                href="/showcase/live2d/"
                data-no-swup
                class="inline-flex items-center text-sm text-neutral-600 dark:text-neutral-400 hover:text-(--primary) transition-colors mb-3"
            >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
                Back to Live2D Models
            </a>
            <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">
                {model.name}
            </h1>
            {model.note && (
                <details class="inni-note mb-4 group">
                    <summary class="cursor-pointer list-none flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-500 dark:text-neutral-400 hover:text-(--primary) select-none transition-colors">
                        <svg class="w-3 h-3 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                        碎碎念
                        <span class="font-normal normal-case tracking-normal text-neutral-400 dark:text-neutral-500 text-[0.65rem]">点击查看</span>
                    </summary>
                    <div class="mt-2 pl-4 border-l-2 border-[color:color-mix(in_oklch,var(--primary)_30%,transparent)]">
                        <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed whitespace-pre-line m-0" set:html={linkify(model.note)}>
                        </p>
                    </div>
                </details>
            )}
            <Live2DPlayer modelPath={model.modelPath} />
        </div>
    </div>
    <Comment path={`/showcase/live2d/${model.slug}/`} />
</GridLayout>
