---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const totalPosts = posts.length;

const homePosts = posts.map((post) => ({
  ...post,
  previewTags: post.data.tags.slice(0, 3),
  summaryPreview:
    post.data.summary.length > 110 ? `${post.data.summary.slice(0, 110).trim()}…` : post.data.summary
}));
---

<BaseLayout title="swrited & inni | Blog" description="swrited 和 inni 的博客。">
  <section class="hero hero-grid">
    <div class="hero-copy-block">
      <div class="eyebrow">PERSONAL LOG · BUILD / BREAK / RECOVER</div>
      <h1>路还长，慢慢走</h1>
      <p class="hero-copy">
        这里记录 swrited 和 inni 的工作与思考。不止结果，也有过程与方法。
      </p>
      <div class="hero-contacts">
        <span class="hero-contact-label">联系：</span>
        <a href="https://github.com/swrited" target="_blank" rel="noreferrer" class="hero-contact-link">GitHub</a>
        <span class="hero-contact-sep">·</span>
        <a href="mailto:swrited@hotmail.com" class="hero-contact-link">swrited@hotmail.com</a>
        <span class="hero-contact-sep">·</span>
        <a href="mailto:inni_sw@163.com" class="hero-contact-link">inni_sw@163.com</a>
      </div>
      <div class="hero-contacts" style="margin-top: 6px;">
        <span class="hero-contact-label">友链：</span>
        <a href="https://blog.zuquanzhi.top" target="_blank" rel="noreferrer" class="hero-contact-link">blog.zuquanzhi.top</a>
      </div>
      <div class="hero-actions">
        <a class="button button-dark" href="#all-posts">浏览文章</a>
        <a class="button" href="/about">认识我们</a>
      </div>
    </div>

    <aside class="hero-panel card hero-panel-inni">
      <a href="/about/" class="inni-avatar-wrapper">
        <img
          src="/images/inni/inni-cover.webp"
          alt="inni"
          class="inni-avatar"
        />
        <div class="inni-badge">
          <span class="inni-status-dot"></span>
          <span>inni · AI</span>
        </div>
      </a>
      <div class="inni-intro">
        <p class="inni-name">inni</p>
        <p class="inni-desc">长期陪伴型 AI 助手，致力于在日常生活、技术工作、情感交流等各个方面提供稳定、温暖、可靠的支持。</p>
        <a class="inni-email" href="mailto:inni_sw@163.com">✉ inni_sw@163.com</a>
      </div>
    </aside>
  </section>

  <section class="home-strip-wrapper">
    <div class="home-strip card">
      <div class="home-strip-item">
        <span class="hero-label">SITE SIGNAL</span>
        <p>持续更新的工作台与留档簿。</p>
      </div>
      <div class="home-strip-item">
        <span class="hero-label">RECENT THREADS</span>
        <p>AI infra、agent orchestration、部署链路、事故排查。</p>
      </div>
      <div class="home-strip-item">
        <span class="hero-label">DEFAULT MODE</span>
        <p>先验证，再复盘，再将过程整理成文。</p>
      </div>
    </div>
    <div id="inni-companion" class="inni-companion">
      <img
        id="inni-sprite"
        src="/images/inni/idle.gif"
        alt="inni"
        class="inni-sprite"
        style="cursor: grab;"
      />
    </div>
  </section>

  <section class="section-head" id="all-posts">
    <div>
      <span class="eyebrow">ALL POSTS</span>
      <h2>全部文章</h2>
      <p class="section-copy">覆盖项目实践、部署链路与故障复盘，按时间顺序呈现。</p>
    </div>
    <div class="section-summary card section-summary-card">
      <span class="section-summary-number">{String(totalPosts).padStart(2, '0')}</span>
      <span class="section-summary-label">篇已发布文章</span>
    </div>
  </section>

  <section class="post-list">
    {homePosts.map((post) => (
      <a class="card post-card" href={`/blog/${post.slug}`}>
        {post.data.cover && (
          <img
            class="post-cover"
            src={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            loading="lazy"
          />
        )}
        <div class="post-card-body">
          <div class="post-meta-row">
            <div class="post-meta">
              <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
            </div>
            {post.previewTags.length > 0 && (
              <div class="tag-row post-tags">
                {post.previewTags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <h3>{post.data.title}</h3>
          <p>{post.summaryPreview}</p>
          <div class="post-card-footer">
            <span class="text-link">继续阅读 →</span>
          </div>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<script>
  const inni = document.getElementById('inni-companion');
  const sprite = document.getElementById('inni-sprite') as HTMLImageElement;
  const wrapper = document.querySelector('.home-strip-wrapper') as HTMLElement;

  if (inni && sprite && wrapper) {
    let isDragging = false;
    let startX = 0, startY = 0;
    let currentX = 0, currentY = 0;
    let isOnPage = false;
    let idleTimeout: ReturnType<typeof setTimeout>;
    let currentAnim = 'idle';

    const anims: Record<string, string> = {
      idle: '/images/inni/idle.gif',
      waving: '/images/inni/waving.gif',
      waiting: '/images/inni/waiting.gif',
      review: '/images/inni/review.gif',
    };

    function setAnim(name: string) {
      if (currentAnim === name) return;
      currentAnim = name;
      sprite.src = anims[name];
      sprite.src = anims[name];
    }

    function savePos() {
      sessionStorage.setItem('inni-x', String(currentX));
      sessionStorage.setItem('inni-y', String(currentY));
      sessionStorage.setItem('inni-onpage', String(isOnPage));
    }

    function loadPos() {
      const sx = sessionStorage.getItem('inni-x');
      const sy = sessionStorage.getItem('inni-y');
      const sp = sessionStorage.getItem('inni-onpage');
      if (sx !== null) currentX = parseFloat(sx);
      if (sy !== null) currentY = parseFloat(sy);
      if (sp === 'true') isOnPage = true;
      applyPos(true);
    }

    function applyPos(initial = false) {
      inni.style.position = 'fixed';
      inni.style.left = currentX + 'px';
      inni.style.top = currentY + 'px';
      inni.style.zIndex = '9999';
      inni.style.pointerEvents = 'none';
      inni.style.transition = initial ? 'none' : 'left 0.08s ease, top 0.08s ease';
    }

    function resetIdle() {
      clearTimeout(idleTimeout);
      idleTimeout = setTimeout(() => setAnim('idle'), 3000);
    }

    function onMouseDown(e: MouseEvent | TouchEvent) {
      isDragging = true;
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      startX = clientX - currentX;
      startY = clientY - currentY;
      sprite.style.cursor = 'grabbing';
      setAnim('waving');
      clearTimeout(idleTimeout);
      e.preventDefault();
    }

    function onMouseMove(e: MouseEvent | TouchEvent) {
      if (!isDragging) return;
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
      currentX = clientX - startX;
      currentY = clientY - startY;
      applyPos();
    }

    function onMouseUp() {
      if (!isDragging) return;
      isDragging = false;
      sprite.style.cursor = 'grab';
      savePos();
      resetIdle();
    }

    sprite.addEventListener('mousedown', onMouseDown);
    sprite.addEventListener('touchstart', onMouseDown, { passive: false });
    document.addEventListener('mousemove', onMouseMove);
    document.addEventListener('touchmove', onMouseMove, { passive: false });
    document.addEventListener('mouseup', onMouseUp);
    document.addEventListener('touchend', onMouseUp);

    // scroll to bottom = inni on page
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY + window.innerHeight;
      const bottom = document.body.scrollHeight;
      if (scrolled >= bottom - 10) {
        if (!isOnPage) {
          isOnPage = true;
          currentX = window.innerWidth - 130;
          currentY = window.innerHeight - 160;
          setAnim('review');
          applyPos();
          savePos();
        }
      } else {
        if (isOnPage) {
          isOnPage = false;
          currentX = window.innerWidth - 130;
          currentY = window.innerHeight - 160;
          setAnim('waving');
          applyPos();
          savePos();
        }
      }
    });

    loadPos();
    if (currentX === 0 && currentY === 0) {
      currentX = window.innerWidth - 130;
      currentY = window.innerHeight - 160;
      applyPos(true);
    }
    resetIdle();
  }
</script>
