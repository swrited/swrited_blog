---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const latest = posts[0];
---

<BaseLayout title="swrited | Blog" description="swrited 的个人博客，记录 AI、工程、部署与产品实践。">
  <section class="hero">
    <div class="eyebrow">PERSONAL BLOG · SHIP / BUILD / WRITE</div>
    <h1>写给未来自己的技术记录。</h1>
    <p class="hero-copy">
      这里会放我做过的 AI 工作流、部署实践、代理链路、项目实验，尽量写得真实、可复盘、可复用。
    </p>
    <div class="hero-actions">
      <a class="button button-dark" href="/blog">看文章</a>
      <a class="button" href="/about">认识我</a>
    </div>
  </section>

  <section class="grid two-up">
    <article class="card metric-card">
      <span class="eyebrow">CURRENT FOCUS</span>
      <h2>AI Infra / Agents / Deployment</h2>
      <p>
        最近主要在折腾模型网关、agent 间协作、部署链路，还有一些能真正跑起来的小工具。
      </p>
    </article>
    <article class="card metric-card">
      <span class="eyebrow">FIRST POST</span>
      <h2>{latest.data.title}</h2>
      <p>{latest.data.summary}</p>
      <a class="text-link" href={`/blog/${latest.slug}`}>继续阅读 →</a>
    </article>
  </section>

  <section class="section-head">
    <div>
      <span class="eyebrow">LATEST WRITING</span>
      <h2>最近文章</h2>
    </div>
    <a class="text-link" href="/blog">查看全部 →</a>
  </section>

  <section class="post-list">
    {posts.map((post) => (
      <a class="card post-card" href={`/blog/${post.slug}`}>
        <div class="post-meta">
          <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
          <span>{post.data.tags.join(' · ')}</span>
        </div>
        <h3>{post.data.title}</h3>
        <p>{post.data.summary}</p>
      </a>
    ))}
  </section>
</BaseLayout>
